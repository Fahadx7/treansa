# ────────────────────────────────────────────────────────────────────────────
# TrandSA Environment Variables
# ────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local for development:
#   cp .env.example .env.local
#
# Then fill in the values from:
#   Firebase Console → Project Settings → General → Your apps → Web app
#
# In production (Cloudflare Workers):
#   - VITE_* vars: set during build via wrangler.toml [vars] or dashboard
#   - Non-VITE secrets: use `wrangler secret put SECRET_NAME`
# ────────────────────────────────────────────────────────────────────────────

# ─── Firebase Web Config ────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=trandsa2030.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=trandsa2030
VITE_FIREBASE_STORAGE_BUCKET=trandsa2030.firebasestorage.app
VITE_FIREBASE_MESSAGING_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_FIRESTORE_DB_ID=(default)

# ─── Cloudflare Worker Secrets ──────────────────────────────────────────────
# These are NOT used in the frontend. Set them via:
#   wrangler secret put TWELVE_DATA_KEY
#   wrangler secret put TELEGRAM_BOT_TOKEN
# (and listed here for reference only — do not commit actual values)

# TWELVE_DATA_KEY=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
