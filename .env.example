# TrandSA — Environment Variables Template
# انسخ هذا الملف إلى .env.local وعدّل القيم

# Cloudflare Worker URL — للحصول على الرابط:
# 1. افتح https://dash.cloudflare.com → Workers & Pages → Create Worker
# 2. اسم الـ Worker: trandsa-api
# 3. انسخ محتوى trandsa-api-worker.js
# 4. Deploy → الرابط سيظهر تلقائياً
VITE_API_WORKER_URL=https://trandsa-api.YOUR_SUBDOMAIN.workers.dev
